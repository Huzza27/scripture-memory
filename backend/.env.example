# Backend Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/scripture_memory

# Alternative: MongoDB
# DATABASE_URL=mongodb://localhost:27017/scripture_memory

# Authentication
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRY=7d

# Bible API
BIBLE_API_KEY=your_bible_api_key_here
BIBLE_API_URL=https://api.scripture.api.bible/v1

# AWS S3 (Audio Storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=scripture-memory-songs

# AI Music Generation (TBD - example values)
# OPENAI_API_KEY=your_openai_key
# SUNO_API_KEY=your_suno_key
# MUSIC_GEN_API_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
