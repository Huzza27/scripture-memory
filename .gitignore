# Root .gitignore for Scripture Memory App

# Environment variables
.env
.env.local
.env.*.local

# Editor directories
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# Temporary files
*.tmp
*.temp
.cache/

# Build outputs (from subdirectories)
dist/
build/
*.exe
*.dmg
*.apk
*.ipa

# Database files (local development)
*.db
*.sqlite
*.sqlite3

# Coverage reports
coverage/
*.lcov
.nyc_output/

# Dependency directories (root level only, let subdirs handle their own)
node_modules/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/

# macOS
.DS_Store
.AppleDouble
.LSOverride
